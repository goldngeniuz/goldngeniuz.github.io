<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CSEC Physics — Calculation Bench</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0e1620;
    --panel:#131f2a;
    --panel-raised:#182632;
    --grid:#1e2f3d;
    --hairline:#26394a;
    --ink:#e7edf2;
    --ink-dim:#8fa4b3;
    --cyan:#54e0d0;
    --cyan-dim:#2c6b64;
    --amber:#f2a65a;
    --amber-dim:#7a5730;
    --red:#e26b6b;
    --radius:3px;
    --mono:'JetBrains Mono', monospace;
    --disp:'Space Grotesk', sans-serif;
    --body:'Inter', sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      linear-gradient(var(--grid) 1px, transparent 1px) 0 0/28px 28px,
      linear-gradient(90deg, var(--grid) 1px, transparent 1px) 0 0/28px 28px,
      var(--bg);
    color:var(--ink);
    font-family:var(--body);
    min-height:100vh;
  }
  a{color:var(--cyan);}

  header{
    border-bottom:1px solid var(--hairline);
    padding:28px clamp(16px,4vw,48px) 22px;
    background:linear-gradient(180deg, rgba(14,22,32,.92), rgba(14,22,32,.55));
    position:sticky; top:0; z-index:20; backdrop-filter:blur(6px);
  }
  .brand{ display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; }
  .brand-mark{
    font-family:var(--mono); font-size:12px; letter-spacing:.18em;
    color:var(--amber); border:1px solid var(--amber-dim);
    padding:3px 8px; border-radius:var(--radius);
  }
  h1{ font-family:var(--disp); font-weight:700; font-size:clamp(22px,3.4vw,32px); margin:0; letter-spacing:-0.01em; }
  header p{ margin:8px 0 0; color:var(--ink-dim); font-size:14.5px; max-width:66ch; }

  .layout{ display:grid; grid-template-columns:220px 1fr; gap:0; max-width:1220px; margin:0 auto; }
  @media (max-width:860px){
    .layout{grid-template-columns:1fr;}
    nav.rail{position:static; border-right:none; border-bottom:1px solid var(--hairline);}
  }

  nav.rail{
    border-right:1px solid var(--hairline);
    padding:22px 10px;
    position:sticky; top:98px; align-self:start;
    max-height:calc(100vh - 98px);
    overflow-y:auto;
  }
  nav.rail .grp-label{
    font-family:var(--mono); font-size:10.5px; letter-spacing:.14em;
    color:var(--ink-dim); text-transform:uppercase;
    padding:14px 10px 6px;
  }
  nav.rail button{
    display:block; width:100%; text-align:left;
    background:none; border:none; color:var(--ink-dim);
    font-family:var(--body); font-size:13.5px;
    padding:7px 10px; border-radius:var(--radius);
    cursor:pointer; border-left:2px solid transparent;
  }
  nav.rail button:hover{ color:var(--ink); background:var(--panel-raised); }
  nav.rail button.active{
    color:var(--cyan); border-left:2px solid var(--cyan);
    background:var(--panel-raised); font-weight:600;
  }

  main{ padding:30px clamp(16px,4vw,40px) 80px; min-width:0; }
  section.topic{ display:none; }
  section.topic.active{ display:block; }

  .topic-head{ margin-bottom:22px; }
  .topic-head .eyebrow{ font-family:var(--mono); font-size:11px; letter-spacing:.16em; color:var(--cyan); text-transform:uppercase; }
  .topic-head h2{ font-family:var(--disp); font-size:24px; margin:4px 0 6px; }
  .topic-head p{ color:var(--ink-dim); font-size:14px; max-width:70ch; margin:0; }

  .cards{ display:grid; grid-template-columns:1fr; gap:18px; }

  .card{ background:var(--panel); border:1px solid var(--hairline); border-radius:6px; padding:20px 20px 18px; }
  .card h3{ font-family:var(--disp); font-size:16.5px; margin:0 0 3px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .card h3 .formula{
    font-family:var(--mono); font-size:12.5px; color:var(--amber);
    background:rgba(242,166,90,.08); border:1px solid var(--amber-dim);
    padding:2px 7px; border-radius:var(--radius);
  }
  .card .desc{ color:var(--ink-dim); font-size:13px; margin:2px 0 14px; }

  .field-row{ display:flex; flex-wrap:wrap; gap:12px; margin-bottom:6px; align-items:flex-end; }
  .field{ display:flex; flex-direction:column; gap:5px; flex:1 1 150px; min-width:130px; transition:opacity .15s; }
  .field label{ font-size:12px; color:var(--ink-dim); font-family:var(--mono); }
  .field .input-unit{ display:flex; align-items:stretch; }
  .field input, .field select{
    background:var(--bg); border:1px solid var(--hairline); color:var(--ink);
    font-family:var(--mono); font-size:14px; padding:8px 10px;
    border-radius:var(--radius) 0 0 var(--radius); width:100%; flex:1;
  }
  .field select{ border-radius:var(--radius); }
  .field input:focus, .field select:focus{ outline:2px solid var(--cyan); outline-offset:-1px; }
  .field .unit-tag{
    font-family:var(--mono); font-size:12px; color:var(--ink-dim);
    background:var(--panel-raised); border:1px solid var(--hairline); border-left:none;
    padding:8px 9px; border-radius:0 var(--radius) var(--radius) 0; white-space:nowrap;
  }
  .field.is-target input{
    opacity:.45; cursor:not-allowed;
    background:repeating-linear-gradient(45deg, var(--bg), var(--bg) 4px, #12222d 4px, #12222d 8px);
  }
  .field.is-target label{ color:var(--cyan); }

  .actions{ margin-top:14px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;}
  button.solve, button.solve-vars{
    background:var(--cyan); color:#04211d; border:none; font-family:var(--body);
    font-weight:600; font-size:13.5px; padding:9px 16px; border-radius:var(--radius);
    cursor:pointer;
  }
  button.solve:hover, button.solve-vars:hover{ background:#7ce9dc; }
  button.solve:focus-visible, button.solve-vars:focus-visible{ outline:2px solid var(--ink); outline-offset:2px; }
  .error-msg{ color:var(--red); font-size:12.5px; font-family:var(--mono); }

  .readout{
    margin-top:14px; border:1px solid var(--cyan-dim); border-radius:var(--radius);
    background:linear-gradient(180deg, rgba(84,224,208,.05), rgba(84,224,208,.02));
    padding:14px 16px; display:none;
  }
  .readout.show{ display:block; }
  .readout .step{
    display:grid; grid-template-columns:96px 1fr; gap:10px;
    font-family:var(--mono); font-size:13.5px; padding:5px 0;
    border-bottom:1px dashed rgba(143,164,179,.18);
  }
  .readout .step:last-child{ border-bottom:none; }
  .readout .step .k{ color:var(--ink-dim); font-size:11px; letter-spacing:.08em; text-transform:uppercase; padding-top:2px;}
  .readout .step .v{ color:var(--ink); }
  .readout .result{
    margin-top:8px; padding-top:10px; border-top:1px solid var(--cyan-dim);
    font-family:var(--mono); font-size:17px; color:var(--cyan); font-weight:600;
  }

  .moment-grid{ display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:16px; padding-bottom:4px; }
  @media (max-width:560px){ .moment-grid{ grid-template-columns:1fr; } }
  .moment-col{ border:1px solid var(--hairline); border-radius:var(--radius); padding:12px 12px 12px; background:rgba(255,255,255,.012); }
  .moment-col-head{ font-family:var(--mono); font-size:11.5px; letter-spacing:.08em; color:var(--amber); margin-bottom:10px; text-transform:uppercase; }
  .moment-row{ margin-bottom:8px; gap:8px; align-items:flex-end; }
  .moment-row .field{ min-width:0; flex:1 1 0; margin-bottom:0; }
  .moment-row .field label{ font-size:11px; }
  .moment-row .mremove{
    background:none; border:1px solid var(--hairline); color:var(--ink-dim);
    border-radius:var(--radius); width:32px; height:34px; cursor:pointer; font-size:13px; flex:0 0 auto;
  }
  .moment-row .mremove:hover{ color:var(--red); border-color:var(--red); }
  button.add-term-btn{
    margin-top:4px; background:none; border:1px dashed var(--hairline); color:var(--ink-dim);
    font-family:var(--mono); font-size:12px; padding:6px 10px; border-radius:var(--radius);
    cursor:pointer; width:100%;
  }
  button.add-term-btn:hover{ color:var(--cyan); border-color:var(--cyan-dim); }

  footer{
    border-top:1px solid var(--hairline); padding:20px clamp(16px,4vw,48px);
    color:var(--ink-dim); font-size:12.5px; font-family:var(--mono);
    max-width:1220px; margin:0 auto;
  }
  ::selection{ background:var(--cyan-dim); color:#fff; }
</style>
</head>
<body>

<header>
  <div class="brand">
    <span class="brand-mark">CSEC · PHYS</span>
    <h1>Calculation Bench</h1>
  </div>
  <p>An instrument panel for every core CSEC Physics calculation. Every card can now solve for <em>any</em> variable in its formula — pick "Solve for" and fill in the rest. Every readout still shows the full Formula Method: state it, substitute, calculate, and unit.</p>
</header>

<div class="layout">
  <nav class="rail" id="rail">
    <div class="grp-label">Physical Measurements</div>
    <button data-target="measurement" class="active">Density &amp; Volume</button>

    <div class="grp-label">Mechanics</div>
    <button data-target="kinematics">Motion (SUVAT)</button>
    <button data-target="forces">Force · Weight · Momentum</button>
    <button data-target="pressure-moments">Pressure &amp; Moments</button>
    <button data-target="work-energy">Work · Energy · Power</button>

    <div class="grp-label">Thermal Physics</div>
    <button data-target="thermal">Heat &amp; Temperature</button>
    <button data-target="gaslaws">Gas Laws</button>

    <div class="grp-label">Waves &amp; Light</div>
    <button data-target="waves">Wave Speed</button>
    <button data-target="optics">Refraction &amp; Lenses</button>

    <div class="grp-label">Electricity</div>
    <button data-target="circuits">Ohm's Law &amp; Power</button>
    <button data-target="resistance">Series / Parallel &amp; Charge</button>
    <button data-target="transformers">Transformers</button>

    <div class="grp-label">Atomic Physics</div>
    <button data-target="atomic">Decay &amp; Mass–Energy</button>
  </nav>

  <main id="main"></main>
</div>

<footer>
  METHOD MARKS: state formula → show substitution → calculate → unit. This bench follows that sequence on every readout.
</footer>

<script>
/* ================= Helpers ================= */

function V(id,label,unit,short){ return {id,label,unit,short: short||id}; }
function withDefault(cfg, id, def){ const v=cfg.vars.find(x=>x.id===id); if(v) v.def=def; return cfg; }

function rnd(x){
  if(x===null||x===undefined||!isFinite(x)) return "—";
  if(x===0) return 0;
  const ax=Math.abs(x);
  if(ax<1e-3 || ax>=1e6) return Number(x.toExponential(4));
  return Number(x.toPrecision(6));
}

const SUBDIGITS = {'0':'₀','1':'₁','2':'₂','3':'₃','4':'₄','5':'₅','6':'₆','7':'₇','8':'₈','9':'₉'};
function toSub(n){ return String(n).split('').map(d=>SUBDIGITS[d]||d).join(''); }

/* ---- Formula factories: build {vars, defaultTarget, formula, solvers} ---- */

// A = B x C
function threeVarProduct(A,B,C, formula, defaultTarget){
  return { vars:[A,B,C], defaultTarget, formula, solvers:{
    [A.id]: v=>{ const val=v[B.id]*v[C.id]; return {steps:[
        ["Formula", formula],
        ["Substitute", `${A.short} = ${v[B.id]} × ${v[C.id]}`],
        ["Calculate", `${A.short} = ${rnd(val)}`]
      ], result:`${A.short} = ${rnd(val)} ${A.unit}`};},
    [B.id]: v=>{ if(v[C.id]===0) throw `${C.short} cannot be zero.`; const val=v[A.id]/v[C.id]; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${B.short} = ${A.short} / ${C.short}`],
        ["Substitute", `${B.short} = ${v[A.id]} ÷ ${v[C.id]}`],
        ["Calculate", `${B.short} = ${rnd(val)}`]
      ], result:`${B.short} = ${rnd(val)} ${B.unit}`};},
    [C.id]: v=>{ if(v[B.id]===0) throw `${B.short} cannot be zero.`; const val=v[A.id]/v[B.id]; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${C.short} = ${A.short} / ${B.short}`],
        ["Substitute", `${C.short} = ${v[A.id]} ÷ ${v[B.id]}`],
        ["Calculate", `${C.short} = ${rnd(val)}`]
      ], result:`${C.short} = ${rnd(val)} ${C.unit}`};},
  }};
}

// A = B / C
function ratioCard(A,B,C, formula, defaultTarget){
  return { vars:[A,B,C], defaultTarget, formula, solvers:{
    [A.id]: v=>{ if(v[C.id]===0) throw `${C.short} cannot be zero.`; const val=v[B.id]/v[C.id]; return {steps:[
        ["Formula", formula],
        ["Substitute", `${A.short} = ${v[B.id]} ÷ ${v[C.id]}`],
        ["Calculate", `${A.short} = ${rnd(val)}`]
      ], result:`${A.short} = ${rnd(val)} ${A.unit}`};},
    [B.id]: v=>{ const val=v[A.id]*v[C.id]; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${B.short} = ${A.short} × ${C.short}`],
        ["Substitute", `${B.short} = ${v[A.id]} × ${v[C.id]}`],
        ["Calculate", `${B.short} = ${rnd(val)}`]
      ], result:`${B.short} = ${rnd(val)} ${B.unit}`};},
    [C.id]: v=>{ if(v[A.id]===0) throw `${A.short} cannot be zero.`; const val=v[B.id]/v[A.id]; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${C.short} = ${B.short} / ${A.short}`],
        ["Substitute", `${C.short} = ${v[B.id]} ÷ ${v[A.id]}`],
        ["Calculate", `${C.short} = ${rnd(val)}`]
      ], result:`${C.short} = ${rnd(val)} ${C.unit}`};},
  }};
}

// A = B x C x D
function fourVarProduct(A,B,C,D, formula, defaultTarget){
  return { vars:[A,B,C,D], defaultTarget, formula, solvers:{
    [A.id]: v=>{ const val=v[B.id]*v[C.id]*v[D.id]; return {steps:[
        ["Formula", formula],
        ["Substitute", `${A.short} = ${v[B.id]} × ${v[C.id]} × ${v[D.id]}`],
        ["Calculate", `${A.short} = ${rnd(val)}`]
      ], result:`${A.short} = ${rnd(val)} ${A.unit}`};},
    [B.id]: v=>{ const denom=v[C.id]*v[D.id]; if(denom===0) throw `${C.short} and ${D.short} cannot multiply to zero.`; const val=v[A.id]/denom; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${B.short} = ${A.short} / (${C.short} × ${D.short})`],
        ["Substitute", `${B.short} = ${v[A.id]} ÷ (${v[C.id]} × ${v[D.id]})`],
        ["Calculate", `${B.short} = ${rnd(val)}`]
      ], result:`${B.short} = ${rnd(val)} ${B.unit}`};},
    [C.id]: v=>{ const denom=v[B.id]*v[D.id]; if(denom===0) throw `${B.short} and ${D.short} cannot multiply to zero.`; const val=v[A.id]/denom; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${C.short} = ${A.short} / (${B.short} × ${D.short})`],
        ["Substitute", `${C.short} = ${v[A.id]} ÷ (${v[B.id]} × ${v[D.id]})`],
        ["Calculate", `${C.short} = ${rnd(val)}`]
      ], result:`${C.short} = ${rnd(val)} ${C.unit}`};},
    [D.id]: v=>{ const denom=v[B.id]*v[C.id]; if(denom===0) throw `${B.short} and ${C.short} cannot multiply to zero.`; const val=v[A.id]/denom; return {steps:[
        ["Formula", formula],
        ["Rearrange", `${D.short} = ${A.short} / (${B.short} × ${C.short})`],
        ["Substitute", `${D.short} = ${v[A.id]} ÷ (${v[B.id]} × ${v[C.id]})`],
        ["Calculate", `${D.short} = ${rnd(val)}`]
      ], result:`${D.short} = ${rnd(val)} ${D.unit}`};},
  }};
}

function card(id,title,desc,cfg){
  return { id, title, desc, formula:cfg.formula, vars:cfg.vars, defaultTarget:cfg.defaultTarget, solvers:cfg.solvers };
}

/* ================= Topic / Card data ================= */

const topics = {

  measurement: {
    eyebrow: "Physical Measurements",
    title: "Density &amp; Volume",
    desc: "Density links mass and volume. Work in base SI units (kg, m³) — use the converter below for cm³, g, etc.",
    cards: [
      card("density","Density","Solve for density, mass, or volume.",
        ratioCard(V("rho","ρ — Density","kg/m³","ρ"), V("m","m — Mass","kg","m"), V("V","V — Volume","m³","V"), "ρ = m / V", "rho")),
      { id:"unitconv", legacy:true, title:"Quick Unit Converter", formula:"prefix ↔ SI",
        desc:"Convert a value between a metric prefix and its base SI unit (e.g. cm → m, g → kg).",
        inputs:[{id:"x", label:"Value"}, {id:"pfx", label:"From prefix", type:"select", opts:["centi (×10⁻²)","milli (×10⁻³)","kilo (×10³)","none (base unit)"]}],
        solve(vals){
          const x = vals.x_val;
          const map = {"centi (×10⁻²)":1e-2, "milli (×10⁻³)":1e-3, "kilo (×10³)":1e3, "none (base unit)":1};
          const factor = map[vals.pfx_val];
          const out = x*factor;
          return { steps:[["Rule","value × prefix factor = value in base SI unit"], ["Substitute", `${x} × ${factor}`], ["Calculate", `${x} × ${factor} = ${out}`]], result:`= ${out} (base SI units)` };
        }
      }
    ]
  },

  kinematics: {
    eyebrow: "Mechanics", title: "Motion — Equations of SUVAT",
    desc: "u = initial velocity, v = final velocity, a = acceleration, t = time, s = displacement. Solve for any one.",
    cards: [
      card("vuat","Final velocity","v = u + at — solve for v, u, a, or t.", {
        vars:[V("v","v — Final velocity","m/s"), V("u","u — Initial velocity","m/s"), V("a","a — Acceleration","m/s²"), V("t","t — Time","s")],
        defaultTarget:"v", formula:"v = u + at",
        solvers:{
          v: x=>{ const val=x.u+x.a*x.t; return {steps:[["Formula","v = u + at"],["Substitute",`v = ${x.u} + (${x.a} × ${x.t})`],["Calculate",`v = ${rnd(val)}`]], result:`v = ${rnd(val)} m/s`}; },
          u: x=>{ const val=x.v-x.a*x.t; return {steps:[["Formula","v = u + at"],["Rearrange","u = v − at"],["Substitute",`u = ${x.v} − (${x.a} × ${x.t})`],["Calculate",`u = ${rnd(val)}`]], result:`u = ${rnd(val)} m/s`}; },
          a: x=>{ if(x.t===0) throw "Time cannot be zero."; const val=(x.v-x.u)/x.t; return {steps:[["Formula","v = u + at"],["Rearrange","a = (v − u) / t"],["Substitute",`a = (${x.v} − ${x.u}) ÷ ${x.t}`],["Calculate",`a = ${rnd(val)}`]], result:`a = ${rnd(val)} m/s²`}; },
          t: x=>{ if(x.a===0) throw "a cannot be zero — use s = ut instead."; const val=(x.v-x.u)/x.a; return {steps:[["Formula","v = u + at"],["Rearrange","t = (v − u) / a"],["Substitute",`t = (${x.v} − ${x.u}) ÷ ${x.a}`],["Calculate",`t = ${rnd(val)}`]], result:`t = ${rnd(val)} s`}; },
        }
      }),
      card("suvat2","Displacement","s = ut + ½at² — solve for s, u, a, or t (t uses the quadratic formula).", {
        vars:[V("s","s — Displacement","m"), V("u","u — Initial velocity","m/s"), V("t","t — Time","s"), V("a","a — Acceleration","m/s²")],
        defaultTarget:"s", formula:"s = ut + ½at²",
        solvers:{
          s: x=>{ const val=x.u*x.t+0.5*x.a*x.t*x.t; return {steps:[["Formula","s = ut + ½at²"],["Substitute",`s = (${x.u} × ${x.t}) + (½ × ${x.a} × ${x.t}²)`],["Calculate",`s = ${rnd(val)}`]], result:`s = ${rnd(val)} m`}; },
          u: x=>{ if(x.t===0) throw "Time cannot be zero."; const val=(x.s-0.5*x.a*x.t*x.t)/x.t; return {steps:[["Formula","s = ut + ½at²"],["Rearrange","u = (s − ½at²) / t"],["Substitute",`u = (${x.s} − ${rnd(0.5*x.a*x.t*x.t)}) ÷ ${x.t}`],["Calculate",`u = ${rnd(val)}`]], result:`u = ${rnd(val)} m/s`}; },
          a: x=>{ if(x.t===0) throw "Time cannot be zero."; const val=2*(x.s-x.u*x.t)/(x.t*x.t); return {steps:[["Formula","s = ut + ½at²"],["Rearrange","a = 2(s − ut) / t²"],["Substitute",`a = 2 × (${x.s} − ${x.u}×${x.t}) ÷ ${x.t}²`],["Calculate",`a = ${rnd(val)}`]], result:`a = ${rnd(val)} m/s²`}; },
          t: x=>{
            let roots=[];
            if(x.a===0){
              if(x.u===0) throw "Cannot solve — a and u are both zero.";
              roots=[x.s/x.u];
            } else {
              const disc = x.u*x.u + 2*x.a*x.s;
              if(disc<0) throw "No real solution — discriminant is negative for these values.";
              const sq=Math.sqrt(disc);
              roots=[(-x.u+sq)/x.a, (-x.u-sq)/x.a];
            }
            const valid = roots.filter(r=>r>=-1e-9).map(r=>Math.max(r,0));
            if(valid.length===0) throw "No physically valid (non-negative) time found.";
            const val = Math.min(...valid);
            const note = valid.length>1 && Math.abs(valid[0]-valid[1])>1e-9 ? "  (other mathematical root discarded as negative/irrelevant)" : "";
            return {steps:[["Formula","s = ut + ½at²"],["Rearrange","½at² + ut − s = 0  (quadratic in t)"],["Solve","t = [−u ± √(u² + 2as)] / a"],["Calculate",`t = ${rnd(val)}`]], result:`t = ${rnd(val)} s${note}`};
          },
        }
      }),
