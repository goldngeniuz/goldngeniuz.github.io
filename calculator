          Vp: x=>{ if(x.Ns===0) throw "Secondary turns cannot be zero."; const val=x.Vs*(x.Np/x.Ns); return {steps:[["Formula","Vₛ/Vₚ = Nₛ/Nₚ"],["Rearrange","Vₚ = Vₛ × (Nₚ/Nₛ)"],["Substitute",`Vₚ = ${x.Vs} × (${x.Np}/${x.Ns})`],["Calculate",`Vₚ = ${rnd(val)}`]], result:`Vₚ = ${rnd(val)} V`}; },
          Np: x=>{ if(x.Vs===0) throw "Secondary voltage cannot be zero."; const val=x.Vp*(x.Ns/x.Vs); return {steps:[["Formula","Vₛ/Vₚ = Nₛ/Nₚ"],["Rearrange","Nₚ = Vₚ × (Nₛ/Vₛ)"],["Substitute",`Nₚ = ${x.Vp} × (${x.Ns}/${x.Vs})`],["Calculate",`Nₚ = ${rnd(val)}`]], result:`Nₚ = ${rnd(val)}`}; },
          Ns: x=>{ if(x.Vp===0) throw "Primary voltage cannot be zero."; const val=x.Vs*(x.Np/x.Vp); return {steps:[["Formula","Vₛ/Vₚ = Nₛ/Nₚ"],["Rearrange","Nₛ = Vₛ × (Nₚ/Vₚ)"],["Substitute",`Nₛ = ${x.Vs} × (${x.Np}/${x.Vp})`],["Calculate",`Nₛ = ${rnd(val)}`]], result:`Nₛ = ${rnd(val)}`}; },
        }
      }),
    ]
  },

  atomic: {
    eyebrow:"Atomic Physics", title:"Decay &amp; Mass–Energy",
    desc:"Exponential radioactive decay and Einstein's mass–energy equivalence. Solve for any variable.",
    cards:[
      card("decay","Radioactive decay","N = N₀(½)^(t/t½) — solve for N, N₀, t, or t½.", {
        vars:[V("N","N — Remaining amount",""), V("N0","N₀ — Initial amount","","N₀"), V("t","t — Elapsed time","any"), V("half","t½ — Half-life","same unit as t","t½")],
        defaultTarget:"N", formula:"N = N₀ (½)^(t/t½)",
        solvers:{
          N: x=>{ if(x.half===0) throw "Half-life cannot be zero."; const val=x.N0*Math.pow(0.5,x.t/x.half); return {steps:[["Formula","N = N₀(½)^(t/t½)"],["Substitute",`N = ${x.N0} × (½)^(${x.t}/${x.half})`],["Calculate",`N = ${rnd(val)}`]], result:`N = ${rnd(val)}`}; },
          N0: x=>{ if(x.half===0) throw "Half-life cannot be zero."; const val=x.N/Math.pow(0.5,x.t/x.half); return {steps:[["Formula","N = N₀(½)^(t/t½)"],["Rearrange","N₀ = N / (½)^(t/t½)"],["Substitute",`N₀ = ${x.N} ÷ (½)^(${x.t}/${x.half})`],["Calculate",`N₀ = ${rnd(val)}`]], result:`N₀ = ${rnd(val)}`}; },
          t: x=>{ if(x.N0<=0||x.N<=0) throw "N and N₀ must both be greater than zero."; if(x.half===0) throw "Half-life cannot be zero."; const ratio=x.N/x.N0; const val=x.half*Math.log(ratio)/Math.log(0.5); return {steps:[["Formula","N = N₀(½)^(t/t½)"],["Rearrange","t = t½ × log(N/N₀) / log(½)"],["Substitute",`t = ${x.half} × log(${x.N}/${x.N0}) / log(0.5)`],["Calculate",`t = ${rnd(val)}`]], result:`t = ${rnd(val)}`}; },
          half: x=>{ if(x.N0<=0||x.N<=0) throw "N and N₀ must both be greater than zero."; const ratio=x.N/x.N0; if(ratio===1) throw "N equals N₀ — half-life is undefined (no decay has occurred)."; const val=x.t*Math.log(0.5)/Math.log(ratio); return {steps:[["Formula","N = N₀(½)^(t/t½)"],["Rearrange","t½ = t × log(½) / log(N/N₀)"],["Substitute",`t½ = ${x.t} × log(0.5) / log(${x.N}/${x.N0})`],["Calculate",`t½ = ${rnd(val)}`]], result:`t½ = ${rnd(val)}`}; },
        }
      }),
      card("emc2","Mass–energy equivalence","E = mc² — solve for E or m. c = 3 × 10⁸ m/s.", {
        vars:[V("E","E — Energy","J"), V("m","m — Mass","kg")],
        defaultTarget:"E", formula:"E = mc²",
        solvers:{
          E: x=>{ const c=3e8; const val=x.m*c*c; return {steps:[["Formula","E = mc²"],["Substitute",`E = ${x.m} × (3×10⁸)²`],["Calculate",`E = ${val.toExponential(4)}`]], result:`E = ${val.toExponential(4)} J`}; },
          m: x=>{ const c=3e8; const val=x.E/(c*c); return {steps:[["Formula","E = mc²"],["Rearrange","m = E / c²"],["Substitute",`m = ${x.E} ÷ (3×10⁸)²`],["Calculate",`m = ${val.toExponential(4)}`]], result:`m = ${val.toExponential(4)} kg`}; },
        }
      }),
    ]
  },
};

/* ================= Generic rendering engine (vars-based cards) ================= */

const varsCardIndex = {};

function fieldHTML2(card, v){
  const inputId = `${card.id}_${v.id}`;
  return `<div class="field" data-var="${v.id}" id="fld_${inputId}">
    <label for="${inputId}">${v.label}</label>
    <div class="input-unit">
      <input type="number" step="any" id="${inputId}" placeholder="0" ${v.def!==undefined?`value="${v.def}"`:""}>
      ${v.unit ? `<span class="unit-tag">${v.unit}</span>` : ""}
    </div>
  </div>`;
}

function varsCardHTML(card){
  varsCardIndex[card.id] = card;
  return `
  <div class="card">
    <h3>${card.title} <span class="formula">${card.formula}</span></h3>
    <p class="desc">${card.desc}</p>
    <div class="field-row">${card.vars.map(v=>fieldHTML2(card,v)).join("")}</div>
    <div class="field-row">
      <div class="field" style="flex:1 1 240px;">
        <label for="${card.id}_target">Solve for</label>
        <select id="${card.id}_target" data-card="${card.id}">
          ${card.vars.map(v=>`<option value="${v.id}" ${v.id===card.defaultTarget?"selected":""}>${v.label}</option>`).join("")}
        </select>
      </div>
    </div>
    <div class="actions">
      <button class="solve-vars" data-card="${card.id}">Calculate</button>
      <span class="error-msg" id="err_${card.id}"></span>
    </div>
    <div class="readout" id="readout_${card.id}"></div>
  </div>`;
}

function refreshTargetDisable(card){
  const sel = document.getElementById(`${card.id}_target`);
  if(!sel) return;
  const target = sel.value;
  card.vars.forEach(v=>{
    const fld = document.getElementById(`fld_${card.id}_${v.id}`);
    const inp = document.getElementById(`${card.id}_${v.id}`);
    if(!fld || !inp) return;
    if(v.id === target){ fld.classList.add('is-target'); inp.value = ""; inp.disabled = true; }
    else { fld.classList.remove('is-target'); inp.disabled = false; }
  });
}

/* ---- Legacy simple card (unit converter) ---- */

function legacyFieldHTML(cardId, f){
  const inputId = `${cardId}_${f.id}`;
  if(f.type === "select"){
    return `<div class="field"><label for="${inputId}">${f.label}</label><select id="${inputId}">${f.opts.map(o=>`<option value="${o}">${o}</option>`).join("")}</select></div>`;
  }
  return `<div class="field"><label for="${inputId}">${f.label}</label><div class="input-unit"><input type="number" step="any" id="${inputId}" placeholder="0">${f.unitTag?`<span class="unit-tag">${f.unitTag}</span>`:""}</div></div>`;
}

function legacyCardHTML(card){
  return `
  <div class="card">
    <h3>${card.title} <span class="formula">${card.formula}</span></h3>
    <p class="desc">${card.desc}</p>
    <div class="field-row">${card.inputs.map(f=>legacyFieldHTML(card.id, f)).join("")}</div>
    <div class="actions">
      <button class="solve" data-legacy="${card.id}">Calculate</button>
      <span class="error-msg" id="err_${card.id}"></span>
    </div>
    <div class="readout" id="readout_${card.id}"></div>
  </div>`;
}

const legacyCardIndex = {};

/* ---- Principle of Moments (dynamic rows) ---- */

let pidCounter = 0;
function newPid(){ return ++pidCounter; }

function momentRowHTML(side, pid){
  return `<div class="field-row moment-row" data-side="${side}" data-pid="${pid}">
    <div class="field"><label>F</label><div class="input-unit"><input type="number" step="any" class="mforce" id="f_${pid}" placeholder="0"><span class="unit-tag">N</span></div></div>
    <div class="field"><label>d</label><div class="input-unit"><input type="number" step="any" class="mdist" id="d_${pid}" placeholder="0"><span class="unit-tag">m</span></div></div>
    <button type="button" class="mremove" data-pid="${pid}" data-side="${side}" title="Remove this term">✕</button>
  </div>`;
}

function principleCardHTML(card){
  const acwRows = [1,2,3].map(()=>momentRowHTML('acw', newPid())).join("");
  const cwRows = [1,2,3].map(()=>momentRowHTML('cw', newPid())).join("");
  return `
  <div class="card">
    <h3>${card.title} <span class="formula">${card.formula}</span></h3>
    <p class="desc">${card.desc}</p>
    <div class="moment-grid">
      <div class="moment-col" data-side="acw">
        <div class="moment-col-head">↺ Anticlockwise (ACW)</div>
        <div class="moment-rows" id="rows_acw">${acwRows}</div>
        <button type="button" class="add-term-btn" data-side="acw">+ Add term</button>
      </div>
      <div class="moment-col" data-side="cw">
        <div class="moment-col-head">↻ Clockwise (CW)</div>
        <div class="moment-rows" id="rows_cw">${cwRows}</div>
        <button type="button" class="add-term-btn" data-side="cw">+ Add term</button>
      </div>
    </div>
    <div class="field-row">
      <div class="field" style="flex:1 1 280px;">
        <label for="principle_target">Solve for</label>
        <select id="principle_target"><option value="">— choose the unknown —</option></select>
      </div>
    </div>
    <div class="actions">
      <button class="solve" id="btn_${card.id}" data-custom="principle">Calculate</button>
      <span class="error-msg" id="err_${card.id}"></span>
    </div>
    <div class="readout" id="readout_${card.id}"></div>
  </div>`;
}

function rebuildPrincipleTargetOptions(){
  const sel = document.getElementById('principle_target');
  if(!sel) return;
  const prevVal = sel.value;
  let optionsHTML = '<option value="">— choose the unknown —</option>';
  ['acw','cw'].forEach(side=>{
    const rows = document.querySelectorAll(`#rows_${side} .moment-row`);
    rows.forEach((row, idx)=>{
      const pid = row.dataset.pid;
      const n = idx+1;
      const labels = row.querySelectorAll('.field label');
      if(labels[0]) labels[0].textContent = `F${toSub(n)}`;
      if(labels[1]) labels[1].textContent = `d${toSub(n)}`;
      const sideLabel = side === 'acw' ? 'ACW' : 'CW';
      optionsHTML += `<option value="${side}-${pid}-f">${sideLabel} F${toSub(n)}</option>`;
      optionsHTML += `<option value="${side}-${pid}-d">${sideLabel} d${toSub(n)}</option>`;
    });
  });
  sel.innerHTML = optionsHTML;
  if([...sel.options].some(o=>o.value===prevVal)) sel.value = prevVal;
}

function termsSumInfo(rowsArr, excludeIdx){
  const parts = [];
  let sum = 0;
  rowsArr.forEach((r, idx)=>{
    if(idx === excludeIdx) return;
    if(r.f === 0 && r.d === 0) return;
    parts.push(`(${r.f}×${r.d})`);
    sum += r.f * r.d;
  });
  return { str: parts.length ? `${parts.join(" + ")} = ${rnd(sum)} N·m` : "0 N·m", sum };
}

function readMomentRows(side){
  return [...document.querySelectorAll(`#rows_${side} .moment-row`)].map(row=>{
    const pid = row.dataset.pid;
    const fEl = document.getElementById(`f_${pid}`);
    const dEl = document.getElementById(`d_${pid}`);
    const f = fEl && fEl.value !== "" ? parseFloat(fEl.value) : 0;
    const d = dEl && dEl.value !== "" ? parseFloat(dEl.value) : 0;
    return { pid, f, d };
  });
}

function solvePrinciple(){
  const target = document.getElementById('principle_target').value;
  if(!target) throw "Choose which value (a force or a distance) you want to solve for.";
  const [side, pid, varType] = target.split("-");
  const other = side === "acw" ? "cw" : "acw";

  const sideRows = readMomentRows(side);
  const otherRows = readMomentRows(other);
  const targetRowIdx = sideRows.findIndex(r=>r.pid===pid);
  if(targetRowIdx === -1) throw "That term no longer exists — pick another from the dropdown.";

  const sideKnown = termsSumInfo(sideRows, targetRowIdx);
  const otherKnown = termsSumInfo(otherRows, undefined);
  const targetRow = sideRows[targetRowIdx];
  const partner = varType === "f" ? targetRow.d : targetRow.f;
  if(partner === 0){
    throw `${varType === "f" ? "The distance" : "The force"} for that term is 0 — enter it before solving for its pair.`;
  }

  const acwInfo = side === "acw" ? sideKnown : otherKnown;
  const cwInfo  = side === "cw"  ? sideKnown : otherKnown;
  const x = side === "acw" ? (cwInfo.sum - acwInfo.sum) / partner : (acwInfo.sum - cwInfo.sum) / partner;

  const posLabel = targetRowIdx + 1;
  const varLabel = varType === "f" ? `F${toSub(posLabel)}` : `d${toSub(posLabel)}`;
  const eq = side === "acw"
    ? `${rnd(acwInfo.sum)} + (${varLabel} × ${partner}) = ${rnd(cwInfo.sum)}`
    : `${rnd(acwInfo.sum)} = ${rnd(cwInfo.sum)} + (${varLabel} × ${partner})`;

  const steps = [
    ["Formula", "ΣM(ACW) = ΣM(CW)"],
    ["ACW terms", acwInfo.str],
    ["CW terms", cwInfo.str],
    ["Equation", eq],
    ["Rearrange", `${varLabel} = (${side==="acw"?rnd(cwInfo.sum):rnd(acwInfo.sum)} − ${side==="acw"?rnd(acwInfo.sum):rnd(cwInfo.sum)}) ÷ ${partner}`],
    ["Calculate", `${varLabel} = ${rnd(x)}`],
  ];
  const unit = varType === "f" ? "N" : "m";
  let note = "";
  if(x < 0) note = "  — a negative result usually means a distance or force was entered on the wrong side.";
  return { steps, result: `${varLabel} (${side.toUpperCase()}) = ${rnd(x)} ${unit}${note}` };
}

/* ================= Page assembly ================= */

function cardHTML(card){
  if(card.custom === "principle") return principleCardHTML(card);
  if(card.legacy) { legacyCardIndex[card.id] = card; return legacyCardHTML(card); }
  return varsCardHTML(card);
}

function renderTopic(id){
  const t = topics[id];
  const section = document.createElement('section');
  section.className = "topic";
  section.id = `topic_${id}`;
  section.innerHTML = `
    <div class="topic-head">
      <div class="eyebrow">${t.eyebrow}</div>
      <h2>${t.title}</h2>
      <p>${t.desc}</p>
    </div>
    <div class="cards">${t.cards.map(c=>cardHTML(c)).join("")}</div>
  `;
  return section;
}

const main = document.getElementById('main');
const rail = document.getElementById('rail');

Object.keys(topics).forEach(id=>{ main.appendChild(renderTopic(id)); });
document.getElementById('topic_measurement').classList.add('active');

Object.values(varsCardIndex).forEach(c=>refreshTargetDisable(c));
rebuildPrincipleTargetOptions();

rail.querySelectorAll('button[data-target]').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    rail.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('section.topic').forEach(s=>s.classList.remove('active'));
    document.getElementById(`topic_${btn.dataset.target}`).classList.add('active');
    window.scrollTo({top:0, behavior:'smooth'});
  });
});

main.addEventListener('change', (e)=>{
  if(e.target.matches('select[id$="_target"]') && e.target.dataset.card){
    const c = varsCardIndex[e.target.dataset.card];
    if(c) refreshTargetDisable(c);
  }
});

main.addEventListener('click', (e)=>{
  const addBtn = e.target.closest('.add-term-btn');
  if(addBtn){
    const side = addBtn.dataset.side;
    const container = document.getElementById(`rows_${side}`);
    if(container.children.length >= 8) return;
    container.insertAdjacentHTML('beforeend', momentRowHTML(side, newPid()));
    rebuildPrincipleTargetOptions();
    return;
  }
  const rmBtn = e.target.closest('.mremove');
  if(rmBtn){
    const row = rmBtn.closest('.moment-row');
    if(row) row.remove();
    rebuildPrincipleTargetOptions();
    return;
  }

  const solveBtn = e.target.closest('button.solve-vars');
  if(solveBtn){
    const card = varsCardIndex[solveBtn.dataset.card];
    const errEl = document.getElementById(`err_${card.id}`);
    const readoutEl = document.getElementById(`readout_${card.id}`);
    errEl.textContent = "";
    try{
      const target = document.getElementById(`${card.id}_target`).value;
      const vals = {};
      card.vars.forEach(v=>{
        const raw = document.getElementById(`${card.id}_${v.id}`).value;
        vals[v.id] = raw === "" ? 0 : parseFloat(raw);
      });
      const out = card.solvers[target](vals);
      readoutEl.innerHTML = out.steps.map(([k,v])=>`<div class="step"><div class="k">${k}</div><div class="v">${v}</div></div>`).join("") + `<div class="result">${out.result}</div>`;
      readoutEl.classList.add('show');
    }catch(err){
      errEl.textContent = typeof err === "string" ? err : "Check your inputs.";
      readoutEl.classList.remove('show');
    }
    return;
  }

  const genericBtn = e.target.closest('button.solve');
  if(genericBtn && genericBtn.dataset.custom === "principle"){
    const errEl = document.getElementById('err_principle');
    const readoutEl = document.getElementById('readout_principle');
    errEl.textContent = "";
    try{
      const out = solvePrinciple();
      readoutEl.innerHTML = out.steps.map(([k,v])=>`<div class="step"><div class="k">${k}</div><div class="v">${v}</div></div>`).join("") + `<div class="result">${out.result}</div>`;
      readoutEl.classList.add('show');
    }catch(err){
      errEl.textContent = typeof err === "string" ? err : "Check your inputs.";
      readoutEl.classList.remove('show');
    }
    return;
  }

  if(genericBtn && genericBtn.dataset.legacy){
    const card = legacyCardIndex[genericBtn.dataset.legacy];
    const errEl = document.getElementById(`err_${card.id}`);
    const readoutEl = document.getElementById(`readout_${card.id}`);
    errEl.textContent = "";
    try{
      const vals = {};
      card.inputs.forEach(f=>{
        const inputId = `${card.id}_${f.id}`;
        const el = document.getElementById(inputId);
        if(f.type === "select") vals[`${f.id}_val`] = el.value;
        else vals[`${f.id}_val`] = el.value === "" ? 0 : parseFloat(el.value);
      });
      const out = card.solve(vals);
      readoutEl.innerHTML = out.steps.map(([k,v])=>`<div class="step"><div class="k">${k}</div><div class="v">${v}</div></div>`).join("") + `<div class="result">${out.result}</div>`;
      readoutEl.classList.add('show');
    }catch(err){
      errEl.textContent = typeof err === "string" ? err : "Check your inputs.";
      readoutEl.classList.remove('show');
    }
  }
});
</script>
